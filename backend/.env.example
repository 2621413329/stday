# =============================================================================
# AI成长观察系统 — 后端环境变量模板
# 使用方法：复制为 .env 后按实际环境修改
#   cp .env.example .env        # Linux / macOS
#   copy .env.example .env      # Windows CMD
# =============================================================================

# --- 应用基础 ---
PROJECT_NAME=AI成长观察系统
# 开发环境 true；Linux 生产部署建议 false
DEBUG=true

# --- PostgreSQL（必填）---
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# 本机示例：
DATABASE_URL=postgresql+asyncpg://postgres:your_password@127.0.0.1:5432/stday
# 数据库在另一台机器时，将 127.0.0.1 改为数据库服务器 IP

# --- JWT 认证（必填）---
# 生产环境务必替换为随机长字符串（≥32 字符）
JWT_SECRET_KEY=please-change-this-secret-key-in-production
JWT_ALGORITHM=HS256
# Token 有效期（分钟），默认 5256000 ≈ 10 年（客户端本地持久登录）
JWT_EXPIRE_MINUTES=5256000

# --- 教师注册（必填，生产环境务必修改）---
# 教师端注册时填写的密钥，默认 root 仅用于开发
TEACHER_REGISTRATION_SECRET=root

# --- 千问 / DashScope（AI 功能必填）---
# 在 https://dashscope.console.aliyun.com/ 获取 API Key
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 对话模型（故事生成等长文本）
QWEN_CHAT_MODEL=qwen-plus
# 短交互模型（心情分析、小人演出等）；兼容旧名 QWEN_MOOD_REPORT_MODEL
QWEN_FAST_MODEL=qwen-flash
# QWEN_MOOD_REPORT_MODEL=qwen-flash

QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_T2I_MODEL=wan2.5-t2i-preview
QWEN_I2V_MODEL=wan2.5-i2v-preview

# 异步 AI 任务轮询（文生图、图生视频）
QWEN_TASK_POLL_INTERVAL_SEC=3
QWEN_TASK_POLL_TIMEOUT_SEC=300

# --- Linux 运行时（可选，供 deploy/start.sh / systemd 使用，非 pydantic 配置项）---
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=8000
# UVICORN_WORKERS=2
